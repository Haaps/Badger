{
  "name": "badger-components",
  "private": true,
  "version": "1.0.0",
  "description": "Reusable Badger React components with a local preview gallery",
  "type": "module",
  "scripts": {
    "tokens:build": "node scripts/build-tokens.mjs",
    "dev": "node scripts/build-tokens.mjs && vite",
    "dev:stop": "bash scripts/dev-stop.sh",
    "build": "node scripts/build-tokens.mjs && tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  }
}
